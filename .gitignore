# Virtual environments
.venv/
.buildvenv/

# Runtime state markers
.library_ready
.ntx_ready

# Runtime directory — ignore everything except machine config DB files
.runtime/*
!.runtime/configs/
.runtime/configs/*
!.runtime/configs/*/
.runtime/configs/*/*
!.runtime/configs/*/*.db
.runtime/configs/*/.window_geometry

# PyInstaller outputs
build/
dist/

# Python cache
__pycache__/
*.py[cod]
*.pyo

# Databases (user data, not source)
databases/*.db

# Drawings (user files, not source)
drawings/

# OS files
Thumbs.db
desktop.ini
.DS_Store

# Editor
.vscode/
*.swp
