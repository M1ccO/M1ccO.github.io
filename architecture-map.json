{
  "version": 3,
  "description": "Machine-readable architecture map for AI agents and tooling. Describes app ownership, module structure, active support packages, runtime boundaries, dependency rules, and key entry points. Last updated: 2026-04-18.",

  "apps": {
    "toolsAndJawsLibrary": {
      "root": "Tools and jaws Library",
      "entryPoint": "Tools and jaws Library/main.py",
      "mainWindow": "Tools and jaws Library/ui/main_window.py",
      "currentNotes": [
        "Platform overhaul phases 0-9 are complete.",
        "Phase 11 shared support modularization is complete.",
        "Inline detail-panel preview is currently disabled; detached preview is the active primary path.",
        "Measurement editor refactor is active and now uses coordinator modules under ui/measurement_editor/coordinators/."
      ],
      "pages": {
        "toolCatalog": {
          "label": "Tool Library / Tool Catalog",
          "orchestrator": "Tools and jaws Library/ui/home_page.py",
          "support": "Tools and jaws Library/ui/home_page_support/",
          "delegate": "Tools and jaws Library/ui/tool_catalog_delegate.py",
          "sharedScaffolding": [
            "shared/ui/helpers/page_scaffold_common.py",
            "shared/ui/helpers/topbar_common.py",
            "shared/ui/helpers/selection_common.py",
            "shared/ui/helpers/detached_preview_common.py"
          ]
        },
        "jawCatalog": {
          "label": "Jaw Library / Jaw Catalog",
          "orchestrator": "Tools and jaws Library/ui/jaw_page.py",
          "support": "Tools and jaws Library/ui/jaw_page_support/",
          "delegate": "Tools and jaws Library/ui/jaw_catalog_delegate.py",
          "sharedScaffolding": [
            "shared/ui/helpers/page_scaffold_common.py",
            "shared/ui/helpers/topbar_common.py",
            "shared/ui/helpers/selection_common.py",
            "shared/ui/helpers/detached_preview_common.py"
          ]
        },
        "export": "Tools and jaws Library/ui/export_page.py",
        "jawExport": "Tools and jaws Library/ui/jaw_export_page.py"
      },
      "editors": {
        "toolEditor": {
          "dialog": "Tools and jaws Library/ui/tool_editor_dialog.py",
          "support": "Tools and jaws Library/ui/tool_editor_support/"
        },
        "jawEditor": {
          "dialog": "Tools and jaws Library/ui/jaw_editor_dialog.py",
          "support": "Tools and jaws Library/ui/jaw_editor_support/"
        },
        "measurementEditor": {
          "dialog": "Tools and jaws Library/ui/measurement_editor_dialog.py",
          "support": "Tools and jaws Library/ui/measurement_editor/",
          "coordinators": "Tools and jaws Library/ui/measurement_editor/coordinators/",
          "refactorPlan": "Tools and jaws Library/MEASUREMENT_EDITOR_REFACTOR_PLAN.md"
        }
      },
      "supportPackages": {
        "homePageSupport": "Tools and jaws Library/ui/home_page_support/",
        "jawPageSupport": "Tools and jaws Library/ui/jaw_page_support/",
        "toolEditorSupport": "Tools and jaws Library/ui/tool_editor_support/",
        "jawEditorSupport": "Tools and jaws Library/ui/jaw_editor_support/",
        "selectorDialogs": "Tools and jaws Library/ui/selectors/"
      },
      "selectors": {
        "description": "Standalone selector dialogs opened by MainWindow when Setup Manager requests a selection. Each dialog is self-contained — catalog + assignment panel + DONE/CANCEL.",
        "toolSelector": "Tools and jaws Library/ui/selectors/tool_selector_dialog.py",
        "jawSelector": "Tools and jaws Library/ui/selectors/jaw_selector_dialog.py",
        "common": "Tools and jaws Library/ui/selectors/common.py",
        "selectorSessionLifecycle": "Tools and jaws Library/ui/main_window.py",
        "selectorSessionMethods": {
          "_open_selector_dialog_for_session": "creates and shows the appropriate selector dialog for the current session",
          "_on_selector_dialog_submit": "receives result payload from dialog DONE and normalizes it",
          "_on_selector_dialog_cancel": "handles dialog CANCEL and clears selector session state",
          "_send_selector_result_payload": "sends selector result back to Setup Manager via QLocalSocket IPC",
          "_clear_selector_session": "closes dialogs and resets all selector session state",
          "_close_selector_dialogs": "safely closes any open selector dialogs"
        }
      },
      "sharedUiHelpers": {
        "selectorMime": "Tools and jaws Library/ui/selector_mime.py",
        "selectorStateHelpers": "Tools and jaws Library/ui/selector_state_helpers.py",
        "selectorUiHelpers": "Tools and jaws Library/ui/selector_ui_helpers.py",
        "selectorPanelBuilders": "Tools and jaws Library/ui/shared/selector_panel_builders.py"
      },
      "ownedDomains": ["tools", "jaws", "export", "selector workflows"],
      "intentionalBoundaries": [
        "Tools and jaws Library/data/migrations/ remains app-specific",
        "Tools and jaws Library/config.py remains app-specific"
      ]
    },
    "setupManager": {
      "root": "Setup Manager",
      "entryPoint": "Setup Manager/main.py",
      "mainWindow": "Setup Manager/ui/main_window.py",
      "currentNotes": [
        "Setup Manager remains owner of works, logbook, drawings, and print workflows.",
        "Tool and jaw master data stay read-only and come from the sibling app.",
        "Main window and setup page now use extracted support packages.",
        "Drawings page is runtime-capable but preference-gated.",
        "Work Editor refactor is active and tracked in WORK_EDITOR_REFACTOR_STATUS.md.",
        "High-level Work Editor creation is now family-selected via ui/work_editor_factory.py instead of callers directly instantiating the shared base dialog.",
        "Setup routing uses ui/machine_family_runtime.py for machine-family decisions such as jaws vs fixtures and Work Editor shell selection.",
        "Setup Card printing now has a machine-profile-aware content policy in services/setup_card_policy.py; print_service.py remains the shared PDF renderer."
      ],
      "pages": {
        "setupPage": {
          "label": "Works / Setups list",
          "orchestrator": "Setup Manager/ui/setup_page.py",
          "support": "Setup Manager/ui/setup_page_support/"
        },
        "logbook": "Setup Manager/ui/logbook_page.py",
        "drawings": {
          "orchestrator": "Setup Manager/ui/drawing_page.py",
          "support": "Setup Manager/ui/drawing_page_support/"
        }
      },
      "editors": {
        "workEditor": {
          "label": "Work Editor (shared base dialog + family-selected shells)",
          "factory": "Setup Manager/ui/work_editor_factory.py",
          "familyRuntime": "Setup Manager/ui/machine_family_runtime.py",
          "dialog": "Setup Manager/ui/work_editor_dialog.py",
          "support": "Setup Manager/ui/work_editor_support/",
          "refactorStatus": "Setup Manager/WORK_EDITOR_REFACTOR_STATUS.md"
        }
      },
      "supportPackages": {
        "mainWindowSupport": "Setup Manager/ui/main_window_support/",
        "setupPageSupport": "Setup Manager/ui/setup_page_support/",
        "workEditorSupport": "Setup Manager/ui/work_editor_support/"
      },
      "services": {
        "workService": "Setup Manager/services/work_service.py",
        "logbookService": "Setup Manager/services/logbook_service.py",
        "drawService": "Setup Manager/services/draw_service.py",
        "printService": "Setup Manager/services/print_service.py",
        "setupCardPolicy": "Setup Manager/services/setup_card_policy.py"
      },
      "ownedDomains": ["works", "logbook", "drawings", "setup database preferences"],
      "intentionalBoundaries": [
        "Setup Manager/data/migrations.py remains app-specific",
        "Setup Manager/config.py remains app-specific"
      ]
    }
  },

  "shared": {
    "root": "shared",
    "platforms": {
      "catalogPageBase": "shared/ui/platforms/catalog_page_base.py",
      "editorDialogBase": "shared/ui/platforms/editor_dialog_base.py",
      "catalogDelegate": "shared/ui/platforms/catalog_delegate.py",
      "selectorState": "shared/ui/platforms/selector_state.py",
      "exportSpecification": "shared/ui/platforms/export_specification.py"
    },
    "services": [
      "shared/services/localization_service.py",
      "shared/services/ui_preferences_service.py"
    ],
    "models": [
      "shared/models/tool.py",
      "shared/models/jaw.py"
    ],
    "ui": {
      "stlPreview": "shared/ui/stl_preview.py",
      "miniAssignmentCard": "shared/ui/cards/mini_assignment_card.py",
      "commonWidgets": "shared/ui/helpers/common_widgets.py",
      "editorHelpers": "shared/ui/helpers/editor_helpers.py",
      "detachedPreviewCommon": "shared/ui/helpers/detached_preview_common.py",
      "pageScaffoldCommon": "shared/ui/helpers/page_scaffold_common.py",
      "selectionCommon": "shared/ui/helpers/selection_common.py",
      "topbarCommon": "shared/ui/helpers/topbar_common.py",
      "dragdropHelpers": "shared/ui/helpers/dragdrop_helpers.py",
      "editorTable": "shared/ui/helpers/editor_table.py",
      "preferencesDialogBase": "shared/ui/preferences_dialog_base.py"
    },
    "data": {
      "modelPaths": "shared/data/model_paths.py"
    }
  },

  "ipc": {
    "description": "Setup Manager and Tools/Jaws Library communicate via QLocalSocket. Setup Manager opens a named socket server; Tools/Jaws Library connects and sends JSON payloads.",
    "selectorFlow": [
      "Setup Manager sends 'open_selector' command with mode ('tools'|'jaws'), head, spindle, initial_assignments",
      "Tools/Jaws Library MainWindow receives payload → calls _open_selector_dialog_for_session()",
      "User completes selection in ToolSelectorDialog or JawSelectorDialog",
      "Dialog calls on_submit callback → _on_selector_dialog_submit() → _send_selector_result_payload()",
      "MainWindow connects QLocalSocket to callback_server name from payload → sends JSON result"
    ]
  },

  "canonicalSharedModules": {
    "services": [
      "shared.services.localization_service",
      "shared.services.ui_preferences_service"
    ],
    "models": [
      "shared.models.tool",
      "shared.models.jaw"
    ],
    "ui": [
      "shared.ui.stl_preview",
      "shared.ui.preferences_dialog_base",
      "shared.ui.helpers.common_widgets",
      "shared.ui.helpers.editor_helpers",
      "shared.ui.helpers.page_scaffold_common",
      "shared.ui.helpers.selection_common",
      "shared.ui.helpers.topbar_common",
      "shared.ui.helpers.detached_preview_common",
      "shared.ui.helpers.editor_table",
      "shared.ui.cards.mini_assignment_card"
    ],
    "data": [
      "shared.data.model_paths"
    ]
  },

  "dependencyRules": {
    "allow": [
      "app -> shared",
      "app -> app-local"
    ],
    "deny": [
      "Setup Manager -> Tools and jaws Library direct imports",
      "Tools and jaws Library -> Setup Manager direct imports",
      "legacy shared import aliases",
      "home_page_support -> jaw_page_support (or vice versa)"
    ]
  }
}
